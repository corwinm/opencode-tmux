{
  "name": "opencode-tmux",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "CLI tooling for discovering and navigating opencode sessions running in tmux",
  "bin": {
    "opencode-tmux": "src/cli.ts"
  },
  "scripts": {
    "list": "bun run src/cli.ts list",
    "dev": "bun run src/cli.ts",
    "check": "bun run src/cli.ts --help"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5"
  }
}
