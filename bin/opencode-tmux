#!/usr/bin/env bash

set -euo pipefail

CURRENT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CLI="$CURRENT_DIR/src/cli.ts"

if [ ! -f "$CLI" ]; then
  printf 'opencode-tmux: missing CLI at %s\n' "$CLI" >&2
  exit 1
fi

if ! command -v node >/dev/null 2>&1; then
  printf 'opencode-tmux: node is required but was not found in PATH\n' >&2
  exit 1
fi

exec node --disable-warning=ExperimentalWarning "$CLI" "$@"
